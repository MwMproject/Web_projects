# ============================================================
#  MwM Project — .htaccess
#  Apache / Infomaniak
# ============================================================

# ── Encodage ──────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── HTTPS forcé ───────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# ── www → sans www (canonical actuel : mwm-project.ch) ────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Page d'erreur personnalisée ────────────────────────────
ErrorDocument 404 /error.html

# ── Sécurité fichiers sensibles ────────────────────────────
<FilesMatch "\.(htaccess|htpasswd|env|log|sh|sql|bak|orig)$">
  Require all denied
</FilesMatch>

# Bloquer accès direct à PHPMailer
<IfModule mod_rewrite.c>
  RewriteRule ^PHPMailer/.*$ - [F,L]
</IfModule>

# Bloquer .DS_Store et fichiers macOS/backup
<FilesMatch "(^#.*#|\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist|DS_Store)|~)$">
  Require all denied
</FilesMatch>

# ── En-têtes de sécurité ───────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Compression Gzip ──────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE text/xml application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/json
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2
</IfModule>

# ── Cache navigateur ──────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Images
  ExpiresByType image/webp             "access plus 6 months"
  ExpiresByType image/png              "access plus 6 months"
  ExpiresByType image/jpeg             "access plus 6 months"
  ExpiresByType image/svg+xml          "access plus 6 months"
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType image/gif              "access plus 6 months"

  # Fonts
  ExpiresByType font/woff              "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType font/ttf               "access plus 1 year"

  # CSS / JS
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript        "access plus 1 month"

  # HTML — jamais en cache (contenu dynamique)
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>

# ── ETag ──────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
